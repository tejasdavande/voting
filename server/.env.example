# Copy this file to .env and fill in real values.

# Port the API server listens on
PORT=5000

# Secret used to sign/verify JWTs (use a long random string)
PRIVATEKEY=change_me_to_a_long_random_string

# MongoDB connection string (Atlas or local).
# MONGODB_URI is preferred; URL is still supported for backward compatibility.
MONGODB_URI=mongodb://127.0.0.1:27017/voting
