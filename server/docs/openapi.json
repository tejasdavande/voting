{
  "openapi": "3.0.3",
  "info": {
    "title": "Voting System API",
    "version": "1.0.0",
    "description": "Backend for an online voting system. Voters register and log in (JWT); each voter may cast exactly one vote. Admins create candidates and view live tallies.",
    "contact": { "name": "Tejas Davande", "url": "https://github.com/tejasdavande/voting" },
    "license": { "name": "ISC" }
  },
  "servers": [{ "url": "http://localhost:5000", "description": "Local development server" }],
  "tags": [
    { "name": "Users", "description": "Voter registration, login and voting status" },
    { "name": "Candidates", "description": "Candidate management and voting" },
    { "name": "System", "description": "Service health" }
  ],
  "paths": {
    "/health": {
      "get": { "tags": ["System"], "summary": "Health check", "responses": { "200": { "description": "Service is up" } } }
    },
    "/user/signup": {
      "post": {
        "tags": ["Users"],
        "summary": "Register a new voter",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SignupInput" } } } },
        "responses": { "201": { "description": "User created" }, "400": { "$ref": "#/components/responses/BadRequest" } }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["Users"],
        "summary": "Log in and receive a JWT",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginInput" } } } },
        "responses": {
          "200": { "description": "Authenticated", "content": { "application/json": { "example": { "accesstoken": "eyJ...", "userType": "voter" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/user/checkVotingStatus": {
      "get": {
        "tags": ["Users"],
        "summary": "Check whether the current user has voted (and for whom)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Voting status", "content": { "application/json": { "example": { "isvoted": true, "candidate": { "name": "Alice" } } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/candidate/listofcandidate": {
      "get": {
        "tags": ["Candidates"],
        "summary": "List all candidates",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Candidate list" }, "401": { "$ref": "#/components/responses/Unauthorized" } }
      }
    },
    "/candidate/createcandidate": {
      "post": {
        "tags": ["Candidates"],
        "summary": "Create a candidate (admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CandidateInput" } } } },
        "responses": { "201": { "description": "Candidate created" }, "400": { "$ref": "#/components/responses/BadRequest" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/candidate/getcandidatevotes": {
      "get": {
        "tags": ["Candidates"],
        "summary": "Get vote tallies (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Vote tallies" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/candidate/updatecandidatevotes": {
      "post": {
        "tags": ["Candidates"],
        "summary": "Cast a vote (one per voter)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["id"], "properties": { "id": { "type": "string", "description": "Candidate ObjectId" } } } } } },
        "responses": {
          "200": { "description": "Vote recorded" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "description": "Already voted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" } },
    "schemas": {
      "SignupInput": {
        "type": "object",
        "required": ["username", "email", "password"],
        "properties": {
          "username": { "type": "string", "example": "voter1" },
          "email": { "type": "string", "format": "email", "example": "voter1@example.com" },
          "password": { "type": "string", "format": "password", "example": "secret123" },
          "phone_no": { "type": "number", "example": 9876543210 }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string", "example": "voter1" },
          "password": { "type": "string", "format": "password", "example": "secret123" }
        }
      },
      "CandidateInput": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string", "example": "Alice" } }
      },
      "Error": { "type": "object", "properties": { "title": { "type": "string" }, "message": { "type": "string" } } }
    },
    "responses": {
      "BadRequest": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Missing or invalid token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Forbidden": { "description": "Insufficient privileges", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "NotFound": { "description": "Resource not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    }
  }
}
